# Provider credentials for live audit runs. Copy to .env (gitignored) and fill in.
# A run only needs creds for the providers used by its config's `models:` list.

# OpenAI (configs with provider: openai)
OPENAI_API_KEY=

# Groq (historical pilot configs; OpenAI-compatible)
GROQ_API_KEY=

# AWS Bedrock (configs with provider: bedrock — Anthropic + Meta Llama)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=          # only for STS temporary credentials; omit for IAM user keys
AWS_DEFAULT_REGION=us-east-1
